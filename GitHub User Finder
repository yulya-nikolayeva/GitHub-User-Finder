import tkinter as tk
from tkinter import messagebox
import requests
import json
import os

FAVORITES_FILE = "favorites.json"

def load_favorites():
    if os.path.exists(FAVORITES_FILE):
        with open(FAVORITES_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    return []

def save_favorites(favorites):
    with open(FAVORITES_FILE, "w", encoding="utf-8") as f:
        json.dump(favorites, f, ensure_ascii=False, indent=2)

class GitHubUserFinder:
    def __init__(self, root):
        self.root = root
        self.root.title("GitHub User Finder")
        self.root.geometry("700x600")

        self.favorites = load_favorites()

        tk.Label(root, text="Введите имя пользователя GitHub:").pack(pady=10)
        self.entry = tk.Entry(root, width=40)
        self.entry.pack()
        
        tk.Button(root, text="Найти пользователя", command=self.search_user, bg="lightblue").pack(pady=5)

        self.result_text = tk.Text(root, height=12, width=80, state="disabled", wrap="word")
        self.result_text.pack(pady=10, padx=10, fill="both", expand=True)

        self.save_button = tk.Button(root, text="Сохранить в избранное", command=self.save_to_favorites, bg="lightgreen")
        self.save_button.pack(pady=5)

        tk.Label(root, text="Избранные пользователи:").pack()
        self.favorites_listbox = tk.Listbox(root, height=8)
        self.favorites_listbox.pack(fill="x", padx=10, pady=5)

        tk.Button(root, text="Удалить из избранного", command=self.remove_from_favorites, bg="lightcoral").pack(pady=5)

        self.update_favorites_list()
        self.last_user_data = None

    def search_user(self):
        username = self.entry.get().strip()
        if not username:
            messagebox.showerror("Ошибка", "Поле поиска не может быть пустым!")
            return

        url = f"https://api.github.com/users/{username}"
        try:
            response = requests.get(url)
            if response.status_code == 200:
                data = response.json()
                self.last_user_data = data
                self.display_user(data)
            elif response.status_code == 404:
                messagebox.showerror("Ошибка", f"Пользователь '{username}' не найден")
                self.last_user_data = None
            else:
                messagebox.showerror("Ошибка", f"Ошибка API: {response.status_code}")
        except Exception as e:
            messagebox.showerror("Ошибка", f"Не удалось подключиться: {e}")
            self.last_user_data = None

    def display_user(self, data):
        self.result_text.config(state="normal")
        self.result_text.delete(1.0, tk.END)
        info = f"""
Логин: {data.get('login', '—')}
Имя: {data.get('name', '—')}
Профиль: {data.get('html_url', '—')}
Репозиториев: {data.get('public_repos', 0)}
Подписчиков: {data.get('followers', 0)}
Дата: {data.get('created_at', '—').split('T')[0]}
        """
        self.result_text.insert(tk.END, info)
        self.result_text.config(state="disabled")

    def save_to_favorites(self):
        if not self.last_user_data:
            messagebox.showwarning("Нет данных", "Сначала найдите пользователя")
            return
        login = self.last_user_data['login']
        if any(fav['login'] == login for fav in self.favorites):
            messagebox.showinfo("Уже есть", f"{login} уже в избранном")
            return
        favorite_info = {
            "login": login,
            "name": self.last_user_data.get('name', '—'),
            "url": self.last_user_data['html_url']
        }
        self.favorites.append(favorite_info)
        save_favorites(self.favorites)
        self.update_favorites_list()
        messagebox.showinfo("Сохранено", f"{login} добавлен")

    def update_favorites_list(self):
        self.favorites_listbox.delete(0, tk.END)
        for fav in self.favorites:
            self.favorites_listbox.insert(tk.END, f"{fav['login']} — {fav['name']}")

    def remove_from_favorites(self):
        selection = self.favorites_listbox.curselection()
        if not selection:
            messagebox.showwarning("Ошибка", "Выберите пользователя")
            return
        removed = self.favorites.pop(selection[0])
        save_favorites(self.favorites)
        self.update_favorites_list()
        messagebox.showinfo("Удалено", f"{removed['login']} удалён")

if __name__ == "__main__":
    root = tk.Tk()
    app = GitHubUserFinder(root)
    root.mainloop()
